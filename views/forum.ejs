<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WithHer - Community Forum</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body { background: #fff5f8; font-family: 'Segoe UI', sans-serif; }
        .navbar { background: linear-gradient(135deg, #ff6b9d, #c44569); }
        .navbar-brand, .nav-link { color: white !important; }
        .page-header {
            background: linear-gradient(135deg, #ff6b9d, #c44569);
            color: white; padding: 30px 20px;
            border-radius: 0 0 30px 30px; text-align: center;
        }
        .post-card {
            background: white; border-radius: 15px;
            padding: 20px; margin-bottom: 15px;
            box-shadow: 0 3px 15px rgba(0,0,0,0.08);
            border-left: 4px solid #ff6b9d;
        }
        .post-card.related { border-left: 4px solid #c44569; background: #fff8fb; }
        .post-card .author { color: #ff6b9d; font-weight: bold; font-size: 0.85rem; }
        .post-card .time { color: #aaa; font-size: 0.8rem; }
        .post-card .content { margin-top: 10px; color: #444; }
        .new-post-box {
            background: white; border-radius: 20px;
            padding: 25px; box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            margin-bottom: 20px;
        }
        .btn-pink {
            background: linear-gradient(135deg, #ff6b9d, #c44569);
            color: white; border: none; border-radius: 10px;
            padding: 10px 25px; margin-top: 10px; width: 100%;
        }
        .btn-pink:hover { opacity: 0.9; color: white; }
        .anonymous-badge {
            background: #f0f0f0; color: #888;
            padding: 3px 10px; border-radius: 20px; font-size: 0.75rem;
        }
        .action-btn {
            background: none; border: 1px solid #ffccd5;
            color: #ff6b9d; border-radius: 20px;
            padding: 3px 12px; font-size: 0.85rem;
            cursor: pointer; text-decoration: none;
            display: inline-block;
        }
        .action-btn:hover { background: #fff0f5; color: #ff6b9d; }
        .action-btn.liked {
            background: linear-gradient(135deg, #ff6b9d, #c44569);
            color: white; border-color: transparent;
        }
        .section-label {
            font-size: 0.8rem; font-weight: bold;
            text-transform: uppercase; letter-spacing: 0.5px;
            margin-bottom: 10px; padding: 6px 14px;
            border-radius: 20px; display: inline-block;
        }
        .section-label.related { background: #ffe0ec; color: #c44569; }
        .section-label.all { background: #f0f0f0; color: #888; }
        .tag-pill {
            background: #fff0f5; color: #c44569;
            border-radius: 20px; padding: 2px 10px;
            font-size: 0.72rem; margin-right: 4px;
            display: inline-block; margin-top: 6px;
        }
        .comments-section {
            margin-top: 14px; border-top: 1px solid #fff0f5; padding-top: 12px;
        }
        .comment-item {
            background: #fff5f8; border-radius: 10px;
            padding: 10px 14px; margin-bottom: 8px; font-size: 0.85rem;
        }
        .comment-author { font-weight: bold; color: #c44569; font-size: 0.78rem; margin-bottom: 3px; }
        .comment-time { color: #bbb; font-size: 0.72rem; }
        .comment-input-row { display: flex; gap: 8px; align-items: center; margin-top: 10px; }
        .comment-input-row input {
            flex: 1; border: 1px solid #ffccd5; border-radius: 20px;
            padding: 7px 14px; font-size: 0.83rem; outline: none;
        }
        .comment-input-row input:focus { border-color: #ff6b9d; }
        .comment-send-btn {
            background: linear-gradient(135deg, #ff6b9d, #c44569);
            color: white; border: none; border-radius: 50%;
            width: 34px; height: 34px; cursor: pointer;
            display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        }
        /* Media */
        .post-media {
            margin-top: 12px; border-radius: 12px;
            overflow: hidden; max-height: 400px;
        }
        .post-media img {
            width: 100%; max-height: 400px;
            object-fit: cover; border-radius: 12px;
        }
        .post-media video {
            width: 100%; max-height: 400px;
            border-radius: 12px; background: #000;
        }
        /* Media preview in post box */
        .media-preview {
            margin-top: 10px; position: relative;
            display: inline-block; max-width: 100%;
        }
        .media-preview img, .media-preview video {
            max-height: 200px; max-width: 100%;
            border-radius: 10px; display: block;
        }
        .media-preview .remove-media {
            position: absolute; top: 6px; right: 6px;
            background: rgba(0,0,0,0.5); color: white;
            border: none; border-radius: 50%;
            width: 24px; height: 24px; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.75rem;
        }
        .attach-btn {
            background: none; border: 1px dashed #ffccd5;
            color: #ff6b9d; border-radius: 10px;
            padding: 8px 16px; font-size: 0.85rem;
            cursor: pointer; margin-top: 10px;
            display: inline-flex; align-items: center; gap: 6px;
        }
        .attach-btn:hover { background: #fff0f5; }
        /* Likes modal */
        .likes-modal-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,0.4); z-index: 9998;
            align-items: center; justify-content: center;
        }
        .likes-modal-overlay.show { display: flex; }
        .likes-modal {
            background: white; border-radius: 20px;
            padding: 25px; width: 320px; max-height: 400px;
            overflow-y: auto; box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        }
        .like-person {
            display: flex; align-items: center; gap: 10px;
            padding: 8px 0; border-bottom: 1px solid #fff5f8;
            font-size: 0.88rem; color: #444;
        }
        .like-person:last-child { border-bottom: none; }
        .like-avatar {
            width: 34px; height: 34px; border-radius: 50%;
            background: linear-gradient(135deg, #ff6b9d, #c44569);
            color: white; display: flex; align-items: center;
            justify-content: center; font-size: 0.85rem; font-weight: bold; flex-shrink: 0;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">WithHer 💗</a>
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link" href="/dashboard"><i class="bi bi-house"></i> Home</a></li>
                <li class="nav-item">
                    <a class="nav-link position-relative" href="#" onclick="toggleNotifications(event)">
                        <i class="bi bi-bell"></i>
                        <span id="notif-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display:none; font-size:0.6rem;"></span>
                    </a>
                </li>
                <li class="nav-item"><a class="nav-link" href="/logout"><i class="bi bi-box-arrow-right"></i> Logout</a></li>
            </ul>
        </div>
    </nav>

    <div class="page-header">
        <h3> Community Forum</h3>
        <p>You are not alone. Share, ask, support.</p>
    </div>

    <div class="container mt-4 pb-5">

        <!-- Search Box -->
        <div style="background:white; border-radius:15px; padding:12px 18px;
            box-shadow:0 3px 15px rgba(0,0,0,0.08); margin-bottom:15px;
            display:flex; align-items:center; gap:10px;">
            <i class="bi bi-search" style="color:#ff6b9d; font-size:1rem;"></i>
            <input type="text" id="forumSearch" placeholder="Search posts by topic or keyword..."
                style="border:none; outline:none; flex:1; font-size:0.9rem; background:transparent;"
                oninput="searchPosts()">
            <button onclick="clearSearch()" id="clearSearchBtn"
                style="display:none; background:none; border:none; color:#aaa; cursor:pointer; font-size:0.85rem;">
                ✕ Clear
            </button>
        </div>

        <!-- New Post Box -->
        <div class="new-post-box">
            <h6 class="mb-3"> Share something or ask a question</h6>
            <textarea class="form-control" id="postContent" rows="3"
                placeholder="What's on your mind? Ask a question, share your experience, or offer support..."></textarea>

            <!-- Media Preview -->
            <div id="mediaPreview" class="media-preview" style="display:none;">
                <div id="mediaPreviewContent"></div>
                <button class="remove-media" onclick="removeMedia()">✕</button>
            </div>

            <!-- Bottom row: attach + anonymous + post -->
            <div class="d-flex align-items-center justify-content-between mt-2 flex-wrap gap-2">
                <div class="d-flex align-items-center gap-2">
                    <button class="attach-btn" onclick="document.getElementById('mediaInput').click()">
                        <i class="bi bi-paperclip"></i> Photo/Video
                    </button>
                    <input type="file" id="mediaInput" accept="image/*,video/*" style="display:none;" onchange="previewMedia(this)">
                </div>
                <div class="form-check mb-0">
                    <input type="checkbox" class="form-check-input" id="isAnonymous" checked>
                    <label class="form-check-label text-muted" for="isAnonymous">Post anonymously</label>
                </div>
            </div>
            <button class="btn-pink" onclick="submitPost()">
                <i class="bi bi-send"></i> Post
            </button>
        </div>

        <div id="postsContainer">
            <div class="text-center text-muted py-4">
                <div class="spinner-border" style="color:#ff6b9d;" role="status"></div>
                <p class="mt-2">Loading posts...</p>
            </div>
        </div>
    </div>

    <!-- Likes Modal -->
    <div class="likes-modal-overlay" id="likesModalOverlay" onclick="closeLikesModal(event)">
        <div class="likes-modal">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="mb-0">💗 Supported by</h6>
                <button onclick="document.getElementById('likesModalOverlay').classList.remove('show')"
                    style="background:none; border:none; color:#aaa; font-size:1.2rem; cursor:pointer;">✕</button>
            </div>
            <div id="likesList"></div>
        </div>
    </div>

    <!-- Notification Dropdown -->
    <div id="notifDropdown" style="display:none; position:fixed; top:56px; right:20px; width:320px;
        background:white; border-radius:15px; box-shadow:0 10px 40px rgba(0,0,0,0.15);
        z-index:9999; max-height:400px; overflow-y:auto;">
        <div style="padding:15px 20px; border-bottom:1px solid #fff0f5;">
            <strong style="color:#c44569;">🔔 Notifications</strong>
            <button onclick="markAllRead()" style="float:right; background:none; border:none; color:#ff6b9d; font-size:0.78rem; cursor:pointer;">Mark all read</button>
        </div>
        <div id="notifList" style="padding:10px 0;">
            <div style="padding:15px 20px; color:#bbb; font-size:0.85rem;">Loading...</div>
        </div>
    </div>

<script>
 const currentUserId = <%- userId %>;
 const isAdmin = <%- isAdmin %>;
 </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let allPostsData = null;
        window.onload = loadPosts;

        async function loadPosts() {
            try {
                const response = await fetch('/forum/posts');
                const data = await response.json();
                allPostsData = data;
                displayPosts(data);
            } catch(err) {
                document.getElementById('postsContainer').innerHTML =
                    '<div class="alert alert-danger">Could not load posts. Please try again.</div>';
            }
        }

        function formatDate(dateStr) {
            return new Date(dateStr).toLocaleDateString('en-KE', {
                day: 'numeric', month: 'short', year: 'numeric'
            });
        }

        function renderPost(post, isRelated = false) {
            const tags = post.tags ? post.tags.split(',').map(t =>
                `<span class="tag-pill">#${t.trim()}</span>`
            ).join('') : '';

            // Media rendering
            let mediaHtml = '';
            if (post.media_url) {
                if (post.media_type === 'video') {
                    mediaHtml = `
                        <div class="post-media">
                            <video controls>
                                <source src="${post.media_url}" type="video/mp4">
                            </video>
                        </div>`;
                } else {
                    mediaHtml = `
                        <div class="post-media">
                            <img src="${post.media_url}" alt="Post image"
                                onclick="window.open('${post.media_url}', '_blank')"
                                style="cursor:zoom-in;">
                        </div>`;
                }
            }

            return `
                <div class="post-card ${isRelated ? 'related' : ''}" id="post-${post.id}">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="author">
                            ${post.is_anonymous
                                ? '<span class="anonymous-badge"> Anonymous Sister</span>'
                                : `<a href="/messages?userId=${post.user_id}&name=${encodeURIComponent(post.full_name)}"
                                      style="color:#ff6b9d; text-decoration:none;">${post.full_name}</a>`}
                        </span>
                        <span class="time">${formatDate(post.created_at)}</span>
                    </div>
                    <div class="content">${post.content}</div>
                    ${mediaHtml}
                    ${tags ? `<div class="mt-1">${tags}</div>` : ''}

                    <div class="mt-2 d-flex align-items-center gap-2 flex-wrap">
                        <button class="action-btn ${post.likes > 0 ? 'liked' : ''}" id="like-btn-${post.id}" onclick="likeAndShow(${post.id}, this)">
                            💗 Support (${post.likes || 0})
                        </button>
                        <button class="action-btn" onclick="toggleComments(${post.id})">
                             Comments
                        </button>
                        ${!post.is_anonymous && post.user_id ? `
                            <a href="/messages?userId=${post.user_id}&name=${encodeURIComponent(post.full_name)}"
                               class="action-btn"> Message</a>
                        ` : ''}
                         ${post.user_id === currentUserId || isAdmin ? `
                     <button class="action-btn" onclick="deletePost(${post.id})" style="border-color:#ff8787; color:#e03131;">
                       Delete
                      </button>
                     ` : ''}
                    </div>

                    <div class="comments-section" id="comments-${post.id}" style="display:none;">
                        <div id="comments-list-${post.id}">
                            <div class="text-muted" style="font-size:0.8rem;">Loading comments...</div>
                        </div>
                        <div class="comment-input-row">
                            <input type="text" id="comment-input-${post.id}"
                                placeholder="Write a comment..."
                                onkeydown="if(event.key==='Enter') submitComment(${post.id})">
                            <button class="comment-send-btn" onclick="submitComment(${post.id})">
                                <i class="bi bi-send-fill" style="font-size:0.75rem;"></i>
                            </button>
                        </div>
                        <div class="form-check mt-1">
                            <input type="checkbox" class="form-check-input" id="anon-comment-${post.id}" checked>
                            <label class="form-check-label text-muted" style="font-size:0.78rem;">Comment anonymously</label>
                        </div>
                    </div>
                </div>
            `;
        }

        // Media preview
        function previewMedia(input) {
            const file = input.files[0];
            if (!file) return;

            const preview = document.getElementById('mediaPreview');
            const content = document.getElementById('mediaPreviewContent');
            const url = URL.createObjectURL(file);

            if (file.type.startsWith('video')) {
                content.innerHTML = `<video src="${url}" controls></video>`;
            } else {
                content.innerHTML = `<img src="${url}" alt="Preview">`;
            }
            preview.style.display = 'inline-block';
        }

        function removeMedia() {
            document.getElementById('mediaInput').value = '';
            document.getElementById('mediaPreview').style.display = 'none';
            document.getElementById('mediaPreviewContent').innerHTML = '';
        }

        // Submit post with media
        async function submitPost() {
            const content = document.getElementById('postContent').value;
            const isAnonymous = document.getElementById('isAnonymous').checked;
            const mediaInput = document.getElementById('mediaInput');

            if (!content.trim() && !mediaInput.files[0]) {
                return alert('Please write something or attach a photo/video!');
            }

            try {
                const formData = new FormData();
                formData.append('content', content);
                formData.append('is_anonymous', isAnonymous);
                if (mediaInput.files[0]) {
                    formData.append('media', mediaInput.files[0]);
                }

                const response = await fetch('/forum/post', {
                    method: 'POST',
                    body: formData // no Content-Type header — browser sets it with boundary
                });

                const data = await response.json();
                if (data.success) {
                    document.getElementById('postContent').value = '';
                    removeMedia();
                    loadPosts();
                } else {
                    alert('Could not post. Please try again.');
                }
            } catch(err) {
                alert('Something went wrong. Please try again.');
            }
        }

        // Search
        function searchPosts() {
            const query = document.getElementById('forumSearch').value.toLowerCase().trim();
            const clearBtn = document.getElementById('clearSearchBtn');
            clearBtn.style.display = query ? 'inline' : 'none';
            if (!allPostsData) return;
            if (!query) { displayPosts(allPostsData); return; }

            const filtered = {
                posts: (allPostsData.posts || []).filter(p =>
                    p.content.toLowerCase().includes(query) ||
                    (p.tags && p.tags.toLowerCase().includes(query))
                ),
                relatedPosts: []
            };

            const container = document.getElementById('postsContainer');
            if (filtered.posts.length === 0) {
                container.innerHTML = `
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-search" style="font-size:2.5rem; color:#ffccd5;"></i>
                        <p class="mt-2">No posts found for "<strong>${query}</strong>"</p>
                    </div>`;
                return;
            }
            container.innerHTML = `
                <div class="mb-2">
                    <span class="section-label all"> ${filtered.posts.length} result${filtered.posts.length > 1 ? 's' : ''} for "${query}"</span>
                </div>
                ${filtered.posts.map(p => renderPost(p, false)).join('')}
            `;
        }

        function clearSearch() {
            document.getElementById('forumSearch').value = '';
            document.getElementById('clearSearchBtn').style.display = 'none';
            if (allPostsData) displayPosts(allPostsData);
        }

        async function likeAndShow(postId, btn) {
            try {
                const response = await fetch(`/forum/like/${postId}`, { method: 'POST' });
                const data = await response.json();
                if (data.success) {
                    btn.innerHTML = `💗 Support (${data.likes})`;
                    data.liked ? btn.classList.add('liked') : btn.classList.remove('liked');
                }
            } catch(err) { console.log('Like error:', err); }
            await showLikes(postId);
        }

        async function showLikes(postId) {
            const overlay = document.getElementById('likesModalOverlay');
            const list = document.getElementById('likesList');
            list.innerHTML = '<div style="color:#bbb; text-align:center; padding:10px;">Loading...</div>';
            overlay.classList.add('show');
            try {
                const res = await fetch(`/forum/likes/${postId}`);
                const likes = await res.json();
                if (likes.length === 0) {
                    list.innerHTML = '<div style="color:#bbb; text-align:center; padding:10px;">No support yet — be the first! 💗</div>';
                    return;
                }
                list.innerHTML = likes.map(l => `
                    <div class="like-person">
                        <div class="like-avatar">${l.full_name.charAt(0).toUpperCase()}</div>
                        <span>${l.full_name}</span>
                    </div>
                `).join('');
            } catch(err) {
                list.innerHTML = '<div style="color:#bbb; text-align:center;">Could not load.</div>';
            }
        }

        async function deletePost(postId) {
    if (!confirm('Delete this post? This cannot be undone.')) return;
    try {
        const res = await fetch(`/forum/delete/${postId}`, { method: 'POST' });
        const data = await res.json();
        if (data.success) {
            document.getElementById(`post-${postId}`).remove();
        } else {
            alert(data.error || 'Could not delete post.');
        }
    } catch(err) {
        alert('Something went wrong.');
    }
}
        function closeLikesModal(e) {
            if (e.target === document.getElementById('likesModalOverlay')) {
                document.getElementById('likesModalOverlay').classList.remove('show');
            }
        }

        async function toggleComments(postId) {
            const section = document.getElementById(`comments-${postId}`);
            const isHidden = section.style.display === 'none';
            if (isHidden) { section.style.display = 'block'; await loadComments(postId); }
            else { section.style.display = 'none'; }
        }

        async function loadComments(postId) {
            const listDiv = document.getElementById(`comments-list-${postId}`);
            try {
                const res = await fetch(`/forum/comments/${postId}`);
                const comments = await res.json();
                if (comments.length === 0) {
                    listDiv.innerHTML = '<p style="color:#bbb; font-size:0.8rem;">No comments yet. Be the first!</p>';
                    return;
                }
                listDiv.innerHTML = comments.map(c => `
                    <div class="comment-item">
                        <div class="d-flex justify-content-between">
                            <span class="comment-author">${c.is_anonymous ? '👤 Anonymous' : c.full_name}</span>
                            <span class="comment-time">${formatDate(c.created_at)}</span>
                        </div>
                        <div style="color:#444; margin-top:3px;">${c.content}</div>
                    </div>
                `).join('');
            } catch(err) {
                listDiv.innerHTML = '<p class="text-danger" style="font-size:0.8rem;">Could not load comments.</p>';
            }
        }

        async function submitComment(postId) {
            const input = document.getElementById(`comment-input-${postId}`);
            const isAnonymous = document.getElementById(`anon-comment-${postId}`).checked;
            const content = input.value.trim();
            if (!content) return;
            try {
                const res = await fetch(`/forum/comment/${postId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content, is_anonymous: isAnonymous })
                });
                const data = await res.json();
                if (data.success) { input.value = ''; await loadComments(postId); }
            } catch(err) { console.log('Comment error:', err); }
        }

        function displayPosts(data) {
            const container = document.getElementById('postsContainer');
            const posts = Array.isArray(data) ? data : (data.posts || []);
            const relatedPosts = Array.isArray(data) ? [] : (data.relatedPosts || []);
            let html = '';

            if (relatedPosts.length > 0) {
                html += `
                    <div class="mb-3">
                        <span class="section-label related">💗 Related to your symptoms</span>
                        <p class="text-muted mb-2" style="font-size:0.82rem;">
                            Based on your recent symptom check — other women sharing similar experiences
                        </p>
                        ${relatedPosts.map(p => renderPost(p, true)).join('')}
                        <hr style="border-color:#ffccd5; margin:20px 0;">
                    </div>`;
            }

            if (posts.length === 0 && relatedPosts.length === 0) {
                html = `
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-chat-heart" style="font-size:3rem; color:#ffccd5;"></i>
                        <p class="mt-2">No posts yet. Be the first to share!</p>
                    </div>`;
            } else if (posts.length > 0) {
                html += `
                    <div class="mb-2"><span class="section-label all">All Posts</span></div>
                    ${posts.map(p => renderPost(p, false)).join('')}`;
            }
            container.innerHTML = html;
        }

        // Notifications
        let notifOpen = false;
        checkUnread();
        setInterval(checkUnread, 30000);

        async function checkUnread() {
            try {
                const res = await fetch('/notifications/unread');
                const data = await res.json();
                const badge = document.getElementById('notif-badge');
                if (data.count > 0) { badge.style.display = 'inline'; badge.innerText = data.count; }
                else { badge.style.display = 'none'; }
            } catch(err) {}
        }

        async function toggleNotifications(e) {
            e.preventDefault();
            const dropdown = document.getElementById('notifDropdown');
            notifOpen = !notifOpen;
            dropdown.style.display = notifOpen ? 'block' : 'none';
            if (notifOpen) await loadNotifications();
        }

        document.addEventListener('click', (e) => {
            const dropdown = document.getElementById('notifDropdown');
            if (notifOpen && !dropdown.contains(e.target) && !e.target.closest('.nav-link')) {
                dropdown.style.display = 'none';
                notifOpen = false;
            }
        });

        async function loadNotifications() {
            const list = document.getElementById('notifList');
            try {
                const res = await fetch('/notifications');
                const notifications = await res.json();
                if (notifications.length === 0) {
                    list.innerHTML = '<div style="padding:15px 20px; color:#bbb; font-size:0.85rem;">No notifications yet 💗</div>';
                    return;
                }
                list.innerHTML = notifications.map(n => `
                    <a href="${n.link || '#'}" style="text-decoration:none;" onclick="markAllRead()">
                        <div style="padding:12px 20px; border-bottom:1px solid #fff5f8;
                                    background:${n.is_read ? 'white' : '#fff8fb'}; cursor:pointer;"
                             onmouseover="this.style.background='#fff0f5'"
                             onmouseout="this.style.background='${n.is_read ? 'white' : '#fff8fb'}'">
                            <div style="font-size:0.85rem; color:#333;">
                                ${n.type === 'comment' ? '' : n.type === 'message' ? '' : '💗'}
                                ${n.message}
                                ${!n.is_read ? '<span style="width:7px;height:7px;background:#ff6b9d;border-radius:50%;display:inline-block;margin-left:5px;"></span>' : ''}
                            </div>
                            <div style="font-size:0.72rem; color:#bbb; margin-top:3px;">
                                ${new Date(n.created_at).toLocaleDateString('en-KE', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' })}
                            </div>
                        </div>
                    </a>
                `).join('');
                await fetch('/notifications/mark-read');
                document.getElementById('notif-badge').style.display = 'none';
            } catch(err) {
                list.innerHTML = '<div style="padding:15px 20px; color:#bbb; font-size:0.85rem;">Could not load notifications.</div>';
            }
        }

        async function markAllRead() {
            await fetch('/notifications/mark-read');
            document.getElementById('notif-badge').style.display = 'none';
            document.getElementById('notifDropdown').style.display = 'none';
            notifOpen = false;
        }
    </script>
</body>
</html>