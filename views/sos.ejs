<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WithHer - Emergency SOS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body { background: #fff5f8; font-family: 'Segoe UI', sans-serif; }
        .navbar { background: linear-gradient(135deg, #ff6b9d, #c44569); }
        .navbar-brand, .nav-link { color: white !important; }
        .page-header {
            background: linear-gradient(135deg, #ff4444, #cc0000);
            color: white;
            padding: 30px 20px;
            border-radius: 0 0 30px 30px;
            text-align: center;
        }
        .sos-btn {
            background: linear-gradient(135deg, #ff4444, #cc0000);
            color: white;
            border: none;
            border-radius: 50%;
            width: 200px;
            height: 200px;
            font-size: 1.3rem;
            font-weight: bold;
            box-shadow: 0 0 30px rgba(255,0,0,0.4);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            margin: 0 auto;
            cursor: pointer;
            transition: transform 0.1s;
        }
        .sos-btn:hover { transform: scale(1.05); }
        .sos-btn:active { transform: scale(0.95); }
        .sos-icon { font-size: 3rem; margin-bottom: 5px; }
        .contact-card {
            background: white;
            border-radius: 15px;
            padding: 15px 20px;
            margin-bottom: 10px;
            box-shadow: 0 3px 15px rgba(0,0,0,0.08);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .add-contact-box {
            background: white;
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            margin-bottom: 20px;
        }
        .btn-pink {
            background: linear-gradient(135deg, #ff6b9d, #c44569);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 10px 20px;
            width: 100%;
            margin-top: 10px;
        }
        .btn-pink:hover { opacity: 0.9; color: white; }
        .status-box {
            border-radius: 15px;
            padding: 15px 20px;
            margin-top: 20px;
            display: none;
        }
        .nearby-facilities {
            background: white;
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            margin-bottom: 20px;
        }
        .facility-item {
            padding: 10px 0;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .facility-item:last-child { border-bottom: none; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">WithHer 💗</a>
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link" href="/dashboard"><i class="bi bi-house"></i> Home</a></li>
                <li class="nav-item"><a class="nav-link" href="/logout"><i class="bi bi-box-arrow-right"></i> Logout</a></li>
            </ul>
        </div>
    </nav>

    <div class="page-header">
        <h3>🚨 Emergency SOS</h3>
        <p>One tap. We alert your emergency contacts.</p>
    </div>

    <div class="container mt-4 pb-5">

        <!-- SOS Button -->
        <div class="text-center mb-4">
            <p class="text-muted mb-3">Press and hold for 2 seconds to send emergency alert</p>
            <button class="sos-btn" id="sosBtn" onmousedown="startSOS()" onmouseup="cancelSOS()"
                ontouchstart="startSOS()" ontouchend="cancelSOS()">
                <span class="sos-icon">🚨</span>
                <span>SOS</span>
                <span style="font-size: 0.8rem;">EMERGENCY</span>
            </button>
            <div class="mt-3">
                <div class="progress" style="height: 8px; display: none;" id="sosProgress">
                    <div class="progress-bar bg-danger" id="sosProgressBar" style="width: 0%; transition: width 2s linear;"></div>
                </div>
            </div>
        </div>

        <!-- Status Box -->
        <div class="status-box alert" id="statusBox"></div>

        <!-- Nearby Emergency Facilities -->
        <div class="nearby-facilities">
            <h6 class="mb-3">🏥 Nearest Emergency Facilities</h6>
            <div id="facilitiesContainer">
                <div class="text-center text-muted py-2">
                    <button class="btn btn-outline-danger rounded-pill" onclick="findNearbyFacilities()">
                        📍 Find Nearest Hospitals
                    </button>
                </div>
            </div>
        </div>

        <!-- Emergency Contacts -->
        <div class="add-contact-box">
            <h6 class="mb-3">👥 My Emergency Contacts</h6>
            <div id="contactsList">
                <p class="text-muted text-center">Loading contacts...</p>
            </div>
        </div>

        <!-- Add Contact Form -->
        <div class="add-contact-box">
            <h6 class="mb-3">➕ Add Emergency Contact</h6>
            <div class="mb-2">
                <input type="text" class="form-control" id="contactName" placeholder="Full Name" required>
            </div>
            <div class="mb-2">
                <input type="text" class="form-control" id="contactPhone" placeholder="Phone Number (07XXXXXXXX)" required>
            </div>
            <div class="mb-2">
                <select class="form-control" id="contactRelationship">
                    <option value="">Select Relationship</option>
                    <option>Mother</option>
                    <option>Father</option>
                    <option>Sister</option>
                    <option>Brother</option>
                    <option>Husband/Partner</option>
                    <option>Friend</option>
                    <option>Doctor</option>
                    <option>Other</option>
                </select>
            </div>
            <button class="btn-pink" onclick="addContact()">
                <i class="bi bi-person-plus"></i> Add Contact
            </button>
        </div>

        <!-- Call Emergency Services -->
        <div class="text-center mt-3">
            <p class="text-muted mb-2">Kenya Emergency Numbers</p>
            <a href="tel:999" class="btn btn-danger rounded-pill me-2">📞 999 Police</a>
            <a href="tel:112" class="btn btn-danger rounded-pill me-2">📞 112 Emergency</a>
            <a href="tel:1199" class="btn btn-warning rounded-pill">🚑 1199 Ambulance</a>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let sosTimer = null;
        let userLocation = null;

        // Load contacts on page load
        window.onload = loadContacts;

        // Get user location
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(
                pos => { userLocation = { lat: pos.coords.latitude, lng: pos.coords.longitude }; },
                err => { console.log('Location not available'); }
            );
        }

        function startSOS() {
            document.getElementById('sosProgress').style.display = 'block';
            document.getElementById('sosProgressBar').style.width = '100%';
            sosTimer = setTimeout(() => { sendSOS(); }, 2000);
        }

        function cancelSOS() {
            clearTimeout(sosTimer);
            document.getElementById('sosProgress').style.display = 'none';
            document.getElementById('sosProgressBar').style.width = '0%';
            document.getElementById('sosProgressBar').style.transition = 'none';
            setTimeout(() => {
                document.getElementById('sosProgressBar').style.transition = 'width 2s linear';
            }, 50);
        }

        async function sendSOS() {
            const statusBox = document.getElementById('statusBox');
            statusBox.style.display = 'block';
            statusBox.className = 'status-box alert alert-warning';
            statusBox.innerHTML = '⏳ Sending emergency alert...';

            try {
                const response = await fetch('/sos/send', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ location: userLocation })
                });

                const data = await response.json();

                if (data.success) {
                    statusBox.className = 'status-box alert alert-success';
                    statusBox.innerHTML = `✅ Emergency alert sent to ${data.contactsNotified} contact(s)! Stay calm — help is on the way.`;
                } else {
                    statusBox.className = 'status-box alert alert-danger';
                    statusBox.innerHTML = '❌ Could not send alert. Please call 999 or 112 directly.';
                }
            } catch(err) {
                statusBox.className = 'status-box alert alert-danger';
                statusBox.innerHTML = '❌ Could not send alert. Please call 999 or 112 directly.';
            }
        }

        async function loadContacts() {
            try {
                const response = await fetch('/sos/contacts');
                const contacts = await response.json();
                const container = document.getElementById('contactsList');

                if (contacts.length === 0) {
                    container.innerHTML = '<p class="text-muted text-center">No emergency contacts added yet.</p>';
                    return;
                }

                container.innerHTML = contacts.map(c => `
                    <div class="contact-card">
                        <div>
                            <strong>${c.name}</strong><br>
                            <small class="text-muted">${c.phone} • ${c.relationship || 'Contact'}</small>
                        </div>
                        <button class="btn btn-outline-danger btn-sm rounded-pill"
                            onclick="deleteContact(${c.id})">Remove</button>
                    </div>
                `).join('');
            } catch(err) {
                document.getElementById('contactsList').innerHTML =
                    '<p class="text-muted text-center">Could not load contacts.</p>';
            }
        }

        async function addContact() {
            const name = document.getElementById('contactName').value;
            const phone = document.getElementById('contactPhone').value;
            const relationship = document.getElementById('contactRelationship').value;

            if (!name || !phone) return alert('Please fill in name and phone number');

            try {
                const response = await fetch('/sos/contacts/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, phone, relationship })
                });

                const data = await response.json();
                if (data.success) {
                    document.getElementById('contactName').value = '';
                    document.getElementById('contactPhone').value = '';
                    document.getElementById('contactRelationship').value = '';
                    loadContacts();
                }
            } catch(err) {
                alert('Could not add contact. Please try again.');
            }
        }

        async function deleteContact(id) {
            if (!confirm('Remove this emergency contact?')) return;
            try {
                await fetch(`/sos/contacts/delete/${id}`, { method: 'DELETE' });
                loadContacts();
            } catch(err) {
                alert('Could not remove contact.');
            }
        }

        function findNearbyFacilities() {
            if (!userLocation) {
                alert('Please allow location access to find nearby hospitals.');
                return;
            }
            const url = `https://www.google.com/maps/search/hospitals+near+me/@${userLocation.lat},${userLocation.lng},14z`;
            window.open(url, '_blank');
        }
    </script>
</body>
</html>